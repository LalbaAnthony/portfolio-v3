{
  "name": "portfolio-v3",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "lint": "eslint .",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "docker:dev": "docker compose --profile dev up --watch",
    "docker:dev:down": "docker compose --profile dev down",
    "docker:prod": "docker compose --profile prod up -d --build",
    "docker:prod:down": "docker compose --profile prod down",
    "docker:down": "docker compose --profile dev --profile prod down",
    "docker:logs": "docker compose --profile dev --profile prod logs -f"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/icon": "^2.2.3",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/robots": "^6.0.9",
    "@nuxtjs/sitemap": "^8.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "eslint": "^10.4.1",
    "nuxt": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "semantic-release": "^25.0.8"
  }
}
